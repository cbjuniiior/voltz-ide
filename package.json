{
  "name": "voltz-ide",
  "version": "0.1.4",
  "description": "Voltz IDE — Multiterminal para Claude Code & Codex (Windows + macOS): splits, abas, monitor por terminal, tags e painel de vídeo.",
  "main": "dist-electron/electron/main.js",
  "author": "Cassio Bona",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELEC -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && node scripts/launch-electron.js",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:icons": "node scripts/build-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:renderer && npm run build:electron",
    "dist": "npm version patch --no-git-tag-version && npm run build:icons && npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "pidtree": "^0.6.0",
    "pidusage": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "29.4.6",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}
